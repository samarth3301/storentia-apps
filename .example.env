NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://username:password@localhost:5432/dbname"

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info

CORS_ORIGIN=http://localhost:3000

# ── Service-to-service authentication ─────────────────────────────────────
# Shared between the core Storentia service and this apps service.
# The core service sends this in the X-Service-Key header on /execute calls.
SERVICE_API_KEY=your-service-api-key-here

# ── Encryption keys (AES-256-GCM) ─────────────────────────────────────────
# Both keys must be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Shared with the core service — used to decrypt incoming execute payloads.
PAYLOAD_ENCRYPTION_KEY=your-64-hex-char-payload-encryption-key-here

# Private to this service — used to encrypt credentials stored in the database.
CREDENTIAL_ENCRYPTION_KEY=your-64-hex-char-credential-encryption-key-here
